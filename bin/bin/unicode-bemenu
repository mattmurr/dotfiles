#!/bin/sh

# The famous "get a menu of emojis to copy" script. (with some modifications to use wl-clipboard and bemenu)

chosen=$(cut -d ';' -f1 ${XDG_DATA_HOME:-$HOME/.local/share}/emoji | bemenu -i -l 8 $@ | sed "s/ .*//")

[ "$chosen" != "" ] || exit

echo "$chosen" | tr -d '\n' | wl-copy
notify-send "'$chosen' copied to clipboard." &
