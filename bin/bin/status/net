#!/bin/sh
# Get the interface name for the default route
CONNAME="$(ip route | awk '/^default/ { print $5 ; exit }')"

# Check if this interface is disconnected
if [ -z $CONNAME ] || [ "$(cat /sys/class/net/$CONNAME/operstate)" = 'down' ]; then
  echo "Disconnected"
  exit
fi

# Get the IP address
IPADDR=$(ip addr show $CONNAME | grep 'inet 192' | \
  awk '{print substr($2, 1, length($2)-3)}')

# If this interface is wireless then use the SSID in place of the interface name.
if [ -d /sys/class/net/${CONNAME}/wireless ]; then
  CONNAME="$(iw "$CONNAME" info | sed -n -e 's/^.*ssid //p')"
  CONNAME="$CONNAME $(grep "^\s*w" /proc/net/wireless | awk '{ print "📶", int($3 * 100 / 70) "%" }')"
fi

echo "$CONNAME"
